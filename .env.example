# Admin web — copy to .env.local
# Use real API (default). Set to "true" only for offline UI with vite-plugin-mock.
VITE_USE_MOCK=false
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# Gaode (AMap) Web JS API — https://console.amap.com/ → 应用管理 → 你的应用 → 添加 Key → 服务平台选「Web端(JS API)」
# Key: the long alphanumeric string shown as「Key」in the key list (NOT the security key).
VITE_AMAP_WEB_KEY=
# Security key (安全密钥): separate string from the Key, required for keys created after 2021-12-02.
# On the console key list row, click「查看安全密钥」or「设置」— copy the jscode into here (no quotes).
# It is NOT your own password, NOT the Web service REST key, NOT the Key value duplicated.
VITE_AMAP_SECURITY_JS_CODE=

# COS CDN images — optional; default imageMogr2/format/webp/quality/88 when unset; set off to disable
# VITE_MEDIA_IMAGE_PROCESS=imageMogr2/format/webp/quality/88

# CI/CD: optional GitHub secret SERVER_DOTENV_B64 = base64 of this file (same directory as package.json; see admin-web/CI_CD.md).
